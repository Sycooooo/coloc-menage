generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String    @id @default(cuid())
  username        String    @unique
  password        String
  avatar          String?
  xp              Int       @default(0)
  currency        Int       @default(0)
  currentStreak   Int       @default(0)
  longestStreak   Int       @default(0)
  lastActiveDate  DateTime?
  createdAt       DateTime  @default(now())

  memberships     UserColoc[]
  assignedTasks   Task[]    @relation("AssignedTasks")
  completedTasks  TaskHistory[]
  scores          Score[]
  items           UserItem[]
  achievements    UserAchievement[]
}

model Colocation {
  id          String    @id @default(cuid())
  name        String
  inviteCode  String    @unique @default(cuid())
  createdAt   DateTime  @default(now())

  members     UserColoc[]
  tasks       Task[]
  scores      Score[]
}

model UserColoc {
  id          String    @id @default(cuid())
  role        String    @default("member")
  joinedAt    DateTime  @default(now())

  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  colocId     String
  coloc       Colocation @relation(fields: [colocId], references: [id], onDelete: Cascade)

  @@unique([userId, colocId])
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("pending")
  difficulty  String    @default("medium")
  category    String?   // "cleaning", "cooking", "sport", "maintenance", "admin"
  room        String?   // "salon", "cuisine", "sdb", "chambre", "exterieur"
  recurrence  String?
  dueDate     DateTime?
  createdAt   DateTime  @default(now())

  colocId     String
  coloc       Colocation @relation(fields: [colocId], references: [id], onDelete: Cascade)

  assignedToId String?
  assignedTo  User?     @relation("AssignedTasks", fields: [assignedToId], references: [id])

  history     TaskHistory[]
}

model TaskHistory {
  id          String    @id @default(cuid())
  completedAt DateTime  @default(now())

  taskId      String
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  completedById String
  completedBy User    @relation(fields: [completedById], references: [id])
}

model Score {
  id      String @id @default(cuid())
  points  Int    @default(0)

  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  colocId String
  coloc   Colocation @relation(fields: [colocId], references: [id], onDelete: Cascade)

  @@unique([userId, colocId])
}

// === Boutique ===

model ShopItem {
  id          String    @id @default(cuid())
  name        String
  description String?
  price       Int
  type        String    // "avatar", "decoration", "badge_style"
  rarity      String    @default("common") // "common", "rare", "epic", "legendary"
  imageUrl    String?
  createdAt   DateTime  @default(now())

  buyers      UserItem[]
}

model UserItem {
  id          String    @id @default(cuid())
  purchasedAt DateTime  @default(now())

  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  itemId      String
  item        ShopItem  @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
}

// === Achievements ===

model Achievement {
  id          String    @id @default(cuid())
  name        String
  description String
  icon        String    // emoji
  condition   String    // ex: "tasks_completed:1", "streak:7", "hard_tasks:10"
  reward      Int       @default(0) // coins gagnes en debloquant

  unlockedBy  UserAchievement[]
}

model UserAchievement {
  id          String    @id @default(cuid())
  unlockedAt  DateTime  @default(now())

  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
}

// === Templates de quêtes ===

model QuestTemplate {
  id            String    @id @default(cuid())
  title         String
  description   String?
  category      String    // "cleaning", "cooking", "sport", "maintenance", "admin"
  room          String?   // "salon", "cuisine", "sdb", "chambre", "exterieur"
  difficulty    String    @default("medium")
  recurrence    String    @default("weekly") // "daily", "weekly", "monthly"
}
